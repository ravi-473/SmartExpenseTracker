# ================================
# Smart Expense Tracker - Backend
# ================================
# IMPORTANT: Never commit this file to GitHub!

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.flueecz.mongodb.net/?appName=Cluster0
# JWT Secret - make this a long random string
# Generate one at: https://randomkeygen.com
JWT_SECRET=your_jwt_secret_here
# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server Port
PORT=5000

# Frontend URL (for CORS)
# In development: http://localhost:5173
# In production: your Vercel URL
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
